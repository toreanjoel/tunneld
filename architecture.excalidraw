      "type": "text",
      "x": 1779.337515485498,
      "y": 718.5745253259053,
      "width": 300.1043090820308,
      "height": 92.28115833716265,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "hachure",
      "strokeWidth": 2,
      "strokeStyle": "dashed",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
