      "index": "au",
      "roundness": null,
      "seed": 1606318296,
      "version": 443,
      "versionNonce": 472323496,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1728767938899,
      "link": null,
      "locked": false,
      "text": "Resolve Server will either serve a\ncustom block screen or it will \nresolve the DNS query and \nreturn the domain response",
      "fontSize": 18.45623166743253,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Resolve Server will either serve a custom block screen or it will resolve the DNS query and return the domain response",
      "autoResize": false,
      "lineHeight": 1.25
    },
    {
      "type": "text",
      "version": 1153,
      "versionNonce": 1077068712,
      "index": "ax",
      "isDeleted": false,
      "id": "T4B6jMpb6rElXGbZwTWe-",
      "fillStyle": "hachure",
      "strokeWidth": 2,
      "strokeStyle": "dashed",
      "roughness": 1,
      "opacity": 100,
      "angle": 0,
      "x": 2377.5996604585216,
      "y": 561.4716315117847,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "width": 358.3417111068795,
      "height": 115.35144792145331,
      "seed": 1099488936,
      "groupIds": [],
      "frameId": null,
      "roundness": null,
      "boundElements": [],
      "updated": 1728767008299,
      "link": null,
      "locked": false,
      "fontSize": 18.45623166743253,
      "fontFamily": 5,
      "text": "Blacklist server will need to have data \nall stored in memory., We can limit how \nmuch it can add to keep memory safe \ni.e 100 items this will block requests to\nadd etc.",
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Blacklist server will need to have data all stored in memory., We can limit how much it can add to keep memory safe i.e 100 items this will block requests to add etc.",
      "autoResize": false,
      "lineHeight": 1.25
    },
    {
      "type": "text",
      "version": 1267,
      "versionNonce": 737397672,
      "index": "ay",
      "isDeleted": false,
      "id": "XZHYrwe5CLxlKjSSl8iF6",
      "fillStyle": "hachure",
      "strokeWidth": 2,
      "strokeStyle": "dashed",
      "roughness": 1,
      "opacity": 100,
      "angle": 0,
      "x": 2543.9458913705016,
      "y": 190.61662957457094,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "width": 333.94805908203074,
      "height": 207.63260625861597,
      "seed": 927293656,
      "groupIds": [],
      "frameId": null,
      "roundness": null,
      "boundElements": [],
      "updated": 1728767212406,
      "link": null,
      "locked": false,
      "fontSize": 18.45623166743253,
      "fontFamily": 5,
      "text": "Store log if request regardkess if \nblacklisted or not including \ninformation around the device that \nmade the request.\n\nLog Retention will be set to 500 \nentries, everything added in memory \nand fs and remove from end when \nadding once limit reached",
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Store log if request regardkess if blacklisted or not including information around the device that made the request.\n\nLog Retention will be set to 500 entries, everything added in memory and fs and remove from end when adding once limit reached",
      "autoResize": false,
      "lineHeight": 1.25
    },
