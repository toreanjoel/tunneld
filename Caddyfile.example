cat Caddyfile
{
	email {$ZROK_USER_EMAIL}
	acme_ca {$CADDY_ACME_API}
	admin 0.0.0.0:2019

	on_demand_tls {
		ask http://127.0.0.1:2015/allow
	}
}

*.{$ZROK_DNS_ZONE}:{$CADDY_HTTPS_PORT} {
	tls {
		dns {$CADDY_DNS_PLUGIN} {$CADDY_DNS_PLUGIN_TOKEN}
		propagation_timeout 60m
	}

	log {
		output stdout
		format console
		level INFO
	}

	# ziti administration console uses :443 for the benefit of a web UI cert and accesses the ziti edge-management API
	@ziti host ziti.{$ZROK_DNS_ZONE}
	reverse_proxy @ziti ziti-quickstart:{$ZITI_CTRL_ADVERTISED_PORT:80} {
		transport http {
			tls_insecure_skip_verify
		}
	}

	@oauth host oauth.{$ZROK_DNS_ZONE}
	reverse_proxy @oauth zrok-frontend:{$ZROK_OAUTH_PORT}

	@ctrl host zrok.{$ZROK_DNS_ZONE}
	reverse_proxy @ctrl zrok-controller:{$ZROK_CTRL_PORT}

	reverse_proxy zrok-frontend:{$ZROK_FRONTEND_PORT} {
		header_up Host {http.request.host}
	}
}


# This will support making anyone set a created domain from this VPS on a domain of theirs
:{$CADDY_HTTPS_PORT} {
	tls {
		on_demand
#		issuer acme {
#			disable_http_challenge
#		}
	}

	log {
		output stdout
		format console
		level INFO
	}

	# Route everything to your frontend (change if needed)
#	reverse_proxy zrok-frontend:{$ZROK_FRONTEND_PORT} {
#		header_up Host {http.request.host}
#	}

	# ---- MANUAL DOMAIN MAPPING(S) ----
	# These need to map to the allowed list to go to a custom domain
	[@LABEL] host toreanjoel.dev www.toreanjoel.dev
	reverse_proxy [@LABEL] [https://TUNNELD_DOMAIN_NAME] {
		header_up Host [TUNNELD_DOMAIN_NAME]
		header_up X-Forwarded-Host {http.request.host}
		header_up X-Forwarded-Proto {scheme}
		header_up X-Forwarded-For {remote}
	}
}

# Internal allow-list endpoint for on_demand_tls 'ask'
:2015 {
	handle_path /allow {
		# Map permitted hostnames
		map {query.domain} {allow} {
      [EXTERNAL_DOMAIN_NAME_THAT_CALLS_ROUTES_TO_SUBDOMAIN] 1
			default 0
		}
		# back ticks needed for the version for the expression
		@ok expression `{allow} == "1"`
		respond @ok 200
		respond 403
	}
}